<AnchorPane fx:id="HomePane" prefHeight="475.0" prefWidth="993.0" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.FireworkRocket.FxmlControl">
   <children>
      <ImageView fx:id="himg" fitHeight="469.0" fitWidth="993.0" layoutY="5.0" onScrollFinished="#himgrecd">
         <image>
            <Image url="@../../Icon/HomeBG.png" />
         </image>
      </ImageView>
      <MFXProgressBar fx:id="PrBar" prefHeight="5.0" prefWidth="993.0" />
      <Label layoutX="14.0" layoutY="14.0" prefHeight="80.0" prefWidth="865.0" text="图片">
         <font>
            <Font size="34.0" />
         </font>
      </Label>
      <Separator layoutY="93.0" prefHeight="0.0" prefWidth="993.0" />
      <MFXButton fx:id="ReGetPic" layoutX="915.0" layoutY="22.0" onAction="#RePicGet" prefHeight="25.0" prefWidth="68.0" text="重新获取" />
      <MFXButton fx:id="APISet" layoutX="915.0" layoutY="54.0" onAction="#APISet" onScroll="#APIset" text="API设置..." />
      <MFXScrollPane fx:id="PicSocPane" layoutY="93.0" opacity="0.69" prefHeight="382.0" prefWidth="993.0">
         <content>
            <GridPane fx:id="PicGridPane" onScroll="#PicGet" prefHeight="380.0" prefWidth="990.0">
              <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <AnchorPane prefHeight="200.0" prefWidth="200.0" GridPane.columnIndex="2" />
                  <AnchorPane prefHeight="200.0" prefWidth="200.0" GridPane.columnIndex="1" />
                  <AnchorPane prefHeight="200.0" prefWidth="200.0" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                  <AnchorPane prefHeight="200.0" prefWidth="200.0" />
                  <AnchorPane prefHeight="200.0" prefWidth="200.0" GridPane.rowIndex="1" />
                  <AnchorPane prefHeight="200.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               </children>
            </GridPane>
         </content>
      </MFXScrollPane>
   </children>
</AnchorPane>
