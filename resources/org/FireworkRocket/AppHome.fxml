<AnchorPane fx:id="HomePane" prefHeight="584.0" prefWidth="993.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.FireworkRocket.FxmlControl">
   <children>
      <HBox layoutY="533.0" prefHeight="51.0" prefWidth="993.0">
         <children>
            <ImageView fitHeight="62.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../Icon/Anime_Index.png" />
               </image>
            </ImageView>
            <MFXButton fx:id="homebu" onAction="#homebu" prefHeight="51.0" prefWidth="166.0" text="主页">
               <graphic>
                  <FontIcon fill="black" iconLiteral="mdi2h-home" iconSize="17" />
               </graphic>
            </MFXButton>
            <MFXButton fx:id="picbu" onAction="#picbu" prefHeight="51.0" prefWidth="166.0" text="图片">
               <graphic>
                 <FontIcon fill="black" iconLiteral="mdi2i-image-area" iconSize="17" />
               </graphic>
            </MFXButton>
            <MFXButton fx:id="vcdbu" onAction="#vcdbu" prefHeight="51.0" prefWidth="166.0" text="番剧">
               <graphic>
                 <FontIcon fill="black" iconLiteral="mdi2m-movie-open" iconSize="17" />
               </graphic>
            </MFXButton>
            <MFXButton fx:id="srchbu" onAction="#srchbu" prefHeight="51.0" prefWidth="166.0" text="搜索">
               <graphic>
                 <FontIcon fill="black" iconLiteral="mdi2c-cloud-search" iconSize="17" />
               </graphic>
            </MFXButton>
            <MFXButton fx:id="ideabu" onAction="#ideabu" prefHeight="51.0" prefWidth="166.0" text="创意库">
               <graphic>
                  <FontIcon fill="black" iconLiteral="mdi2a-account-star" iconSize="17" />
               </graphic>
            </MFXButton>
            <MFXButton fx:id="pugbu" onAction="#pugbu" prefHeight="51.0" prefWidth="166.0" text="插件">
               <graphic>
                  <FontIcon fill="black" iconLiteral="mdi2p-puzzle" iconSize="17" />
               </graphic>
            </MFXButton>
            <MFXButton fx:id="setbu" onAction="#setbu" prefHeight="51.0" prefWidth="166.0" text="设置">
               <graphic>
                  <FontIcon fill="black" iconLiteral="mdi2c-cog" iconSize="17" />
               </graphic>
            </MFXButton>
         </children>
      </HBox>
      <BorderPane prefHeight="527.0" prefWidth="993.0">
         <top>
            <HBox prefHeight="23.0" prefWidth="993.0" BorderPane.alignment="CENTER">
               <children>
                  <MFXButton fx:id="newtabbu" onAction="#newtabbu" prefHeight="35.0" prefWidth="105.0" text="新建标签页">
                     <graphic>
                        <FontIcon fill="black" iconLiteral="mdi2t-tab-plus" iconSize="15" />
                     </graphic>
                  </MFXButton>
                  <MFXButton fx:id="AllTabsClosed" onAction="#AllTabsClosedBU" prefHeight="25.0" prefWidth="127.0" text="关闭所有标签页">
                     <graphic>
                        <FontIcon fill="black" iconLiteral="mdi2t-tab-remove" iconSize="16" />
                     </graphic>
                  </MFXButton>
                  <MFXButton fx:id="newwinbu" onAction="#newwinbu" prefHeight="35.0" prefWidth="90.0" text="新建窗口">
                     <graphic>
                        <FontIcon fill="black" iconLiteral="mdi2c-card-plus" iconSize="15" />
                     </graphic>
                  </MFXButton>
                  <MFXButton fx:id="akeybu" onAction="#akeybu" prefHeight="35.0" prefWidth="105.0" text="定义快捷键...">
                     <graphic>
                        <FontIcon fill="black" iconLiteral="mdi2k-keyboard" iconSize="15" />
                     </graphic>
                  </MFXButton>
                  <MFXButton fx:id="Updatebu" onAction="#Updatebu" prefHeight="25.0" prefWidth="99.0" text="软件更新">
                     <graphic>
                        <FontIcon fill="black" iconLiteral="mdi2u-upload-outline" iconSize="16" />
                     </graphic>
                  </MFXButton>
               </children>
            </HBox>
         </top>
         <center>
            <TabPane fx:id="tabpane" onMouseClicked="#TabClosed" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
              <tabs>
                <Tab text="Anime Index：主页">
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <ImageView fitHeight="470.0" fitWidth="993.0" layoutY="4.0" pickOnBounds="true">
                                 <image>
                                    <Image url="@../../Icon/HomeBG.png" />
                                 </image>
                              </ImageView>
                              <MFXProgressBar fx:id="PrBar" animationSpeed="0.9" prefHeight="4.0" prefWidth="993.0" progress="0.0" />
                              <Label fx:id="WelcomeText" layoutX="14.0" layoutY="14.0" prefHeight="80.0" prefWidth="865.0" text="欢迎使用 Anime Index">
                                 <font>
                                    <Font size="34.0" />
                                 </font>
                              </Label>
                              <Label layoutX="14.0" layoutY="69.0" prefHeight="51.0" prefWidth="310.0" text=" 从下面或底部的选项中选择一个并开始">
                                 <font>
                                    <Font size="17.0" />
                                 </font>
                              </Label>
                              <MFXButton fx:id="hingbu" layoutX="16.0" layoutY="136.0" onAction="#picbu" prefHeight="132.0" prefWidth="158.0" text=" 图片">
                                 <graphic>
                                    <FontIcon fill="black" iconLiteral="mdi2i-image-area" iconSize="30" />
                                 </graphic>
                              </MFXButton>
                              <MFXButton fx:id="hvcdbu" layoutX="187.0" layoutY="136.0" onAction="#vcdbu" prefHeight="132.0" prefWidth="158.0" text=" 番剧">
                                 <graphic>
                                    <FontIcon fill="black" iconLiteral="mdi2m-movie-open" iconSize="30" />
                                 </graphic>
                              </MFXButton>
                              <MFXButton fx:id="hideabu" layoutX="357.0" layoutY="136.0" onAction="#ideabu" prefHeight="132.0" prefWidth="158.0" text=" 创意库">
                                 <graphic>
                                    <FontIcon fill="black" iconLiteral="mdi2a-account-star" iconSize="30" />
                                 </graphic>
                              </MFXButton>
                              <MFXButton fx:id="hsrchbu" layoutX="527.0" layoutY="136.0" onAction="#srchbu" prefHeight="132.0" prefWidth="158.0" text=" 搜索">
                                 <graphic>
                                    <FontIcon fill="black" iconLiteral="mdi2c-cloud-search" iconSize="30" />
                                 </graphic>
                              </MFXButton>
                              <Label layoutX="442.0" layoutY="452.0" text="↓ |下滑以进入推荐| ↓" />
                           </children>
                        </AnchorPane>
                  </content>
                </Tab>
              </tabs>
            </TabPane>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
